{
  "name": "codegen-openapi",
  "version": "1.0.0",
  "description": "Zero-dependency CLI that generates Next.js route handlers, typed services, and React Query hooks from any OpenAPI/Swagger spec",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "openapi-gen": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "nextjs",
    "react",
    "openapi",
    "swagger",
    "codegen",
    "cli",
    "routes",
    "services",
    "hooks",
    "react-query",
    "tanstack",
    "typescript"
  ],
  "author": "Miguel thelastcodee@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Last-Code-MgL/codegen-openapi.git"
  },
  "homepage": "https://github.com/Last-Code-MgL/codegen-openapi#readme",
  "bugs": {
    "url": "https://github.com/Last-Code-MgL/codegen-openapi/issues"
  }
}
